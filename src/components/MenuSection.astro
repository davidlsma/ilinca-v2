---
import { platos } from '../data/menu';

const destacados = platos.filter(p => !p.vegetariano);
const vegetarianos = platos.filter(p => p.vegetariano);
---

<section
  id="menu"
  class="section-pad"
  style="background-color: var(--color-dark);"
>
  <div class="site-container">

    <!-- Encabezado -->
    <div style="margin-bottom: 3.5rem;">
      <p class="label-sm fade-in" style="color: var(--color-primary); margin-bottom: 1rem;">
        Lo que cocinamos
      </p>
      <h2 class="heading-xl fade-in" style="color: var(--color-on-dark);">
        Platos que saben a casa
      </h2>
    </div>

    <!-- Platos destacados -->
    <p class="label-sm fade-in" style="color: var(--color-on-dark-muted); margin-bottom: 1.5rem;">
      Destacados
    </p>
    <div class="menu-grid-3 fade-in" style="margin-bottom: 4rem;">
      {destacados.map(plato => (
        <article class="menu-card">
          <div class="menu-card-img-wrap">
            <img
              src={plato.imagen}
              alt={plato.nombre}
              loading="lazy"
              width="600"
              height="700"
              class="menu-card-img"
            />
          </div>
          <div class="menu-card-body">
            <h3 style="color: var(--color-on-dark); margin-bottom: 0.3rem; font-size: 0.95rem; font-weight: 700;">
              {plato.nombre}
            </h3>
            <p style="color: var(--color-on-dark-muted); font-size: 0.8rem; line-height: 1.5;">
              {plato.descripcion}
            </p>
          </div>
        </article>
      ))}
    </div>

    <!-- Divisor -->
    <div style="border-top: 1px solid rgba(245,237,216,0.1); margin-bottom: 3rem;"></div>

    <!-- Opciones vegetarianas -->
    <p class="label-sm fade-in" style="color: var(--color-primary); margin-bottom: 1.5rem;">
      Opciones vegetarianas
    </p>
    <div class="menu-grid-2 fade-in">
      {vegetarianos.map(plato => (
        <article class="menu-card menu-card--veggie">
          <div class="menu-card-img-wrap">
            <img
              src={plato.imagen}
              alt={plato.nombre}
              loading="lazy"
              width="700"
              height="500"
              class="menu-card-img"
            />
          </div>
          <div class="menu-card-body">
            <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.3rem;">
              <h3 style="color: var(--color-on-dark); font-size: 0.95rem; font-weight: 700;">
                {plato.nombre}
              </h3>
              <span class="veggie-badge">Vegetariano</span>
            </div>
            <p style="color: var(--color-on-dark-muted); font-size: 0.8rem; line-height: 1.5;">
              {plato.descripcion}
            </p>
          </div>
        </article>
      ))}
    </div>

    <div class="fade-in" style="margin-top: 3rem; text-align: center;">
      <a
        href="https://drive.google.com/file/d/1L2iD__9jkkzXSx8fRaEVq6CoW9-aCcKS/view?fbclid=PAZXh0bgNhZW0CMTEAc3J0YwZhcHBfaWQMMjU2MjgxMDQwNTU4AAGn7mfj12RCtrb3NpCs834a03QvywiNV3vDaUMKffrF4aBWP8JidSYo5ZxwvP0_aem_wA6pet2VHmt7CVoGROk0lQ"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        Ver menú completo
      </a>
    </div>

  </div>
</section>

<style>
  .menu-grid-3 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .menu-grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .menu-grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .menu-grid-2 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .menu-card {
    background: var(--color-dark-mid);
    overflow: hidden;
  }

  .menu-card-img-wrap {
    overflow: hidden;
    aspect-ratio: 3/2;
  }

  .menu-card--veggie .menu-card-img-wrap {
    aspect-ratio: 3/2;
  }

  .menu-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .menu-card:hover .menu-card-img {
    transform: scale(1.04);
  }

  .menu-card-body {
    padding: 0.85rem 1.1rem 1.1rem;
  }

  .menu-fotos {
    position: relative;
    height: 520px;
  }

  .menu-foto {
    position: absolute;
    object-fit: cover;
    display: block;
  }

  .menu-foto--1 {
    top: 0;
    left: 0;
    width: 38%;
    height: 72%;
  }

  .menu-foto--2 {
    bottom: 0;
    left: 28%;
    width: 52%;
    height: 78%;
  }

  @media (max-width: 640px) {
    .menu-fotos {
      height: 320px;
    }
  }

  .veggie-badge {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    padding: 0.2rem 0.5rem;
    white-space: nowrap;
  }
</style>
