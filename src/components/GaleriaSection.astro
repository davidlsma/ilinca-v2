---
const imagenes = [
  { src: '/assets/images/gal-1.jpg', alt: 'ILINCA Resto Bar' },
  { src: '/assets/images/gal-2.jpg', alt: 'Ambiente ILINCA' },
  { src: '/assets/images/gal-3.jpg', alt: 'Gastronomía ILINCA' },
  { src: '/assets/images/gal-4.jpg', alt: 'Momentos ILINCA' },
  { src: '/assets/images/gal-5.jpg', alt: 'Platos ILINCA' },
  { src: '/assets/images/gal-6.jpg', alt: 'Eventos ILINCA' },
  { src: '/assets/images/gal-7.jpg', alt: 'Noche en ILINCA' },
  { src: '/assets/images/gal-8.jpg', alt: 'Campo y cocina ILINCA' },
];
---

<section
  id="galeria"
  class="section-pad"
  style="background-color: var(--color-dark);"
>
  <div class="site-container">

    <div style="margin-bottom: 3rem;">
      <p class="label-sm fade-in" style="color: var(--color-primary); margin-bottom: 1rem;">
        Momentos ILINCA
      </p>
      <h2 class="heading-xl fade-in" style="color: var(--color-on-dark);">
        Así se vive acá
      </h2>
    </div>

    <div class="galeria-grid fade-in">

      {imagenes.slice(0, 4).map(img => (
        <div class="galeria-item">
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
            width="600"
            height="600"
            class="galeria-img"
          />
        </div>
      ))}

      <!-- Cuadro Instagram -->
      <a
        href="https://instagram.com/ilinca.restobar"
        target="_blank"
        rel="noopener noreferrer"
        class="galeria-item galeria-instagram"
        aria-label="Seguinos en Instagram"
      >
        <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="opacity: 0.9;">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        <p class="label-sm" style="margin-top: 0.75rem; color: var(--color-surface);">Seguinos</p>
        <p class="ig-handle">@ilinca.restobar</p>
      </a>

      {imagenes.slice(4).map(img => (
        <div class="galeria-item">
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
            width="600"
            height="600"
            class="galeria-img"
          />
        </div>
      ))}

    </div>

  </div>
</section>

<style>
  .galeria-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
  }

  @media (min-width: 768px) {
    .galeria-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .galeria-item {
    overflow: hidden;
    aspect-ratio: 1;
  }

  .galeria-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s ease;
    filter: grayscale(0.15);
  }

  .galeria-item:hover .galeria-img {
    transform: scale(1.05);
    filter: grayscale(0);
  }

  .galeria-instagram {
    background-color: var(--color-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .galeria-instagram:hover {
    background-color: var(--color-primary-dark);
  }

  .ig-handle {
    font-family: var(--font-display);
    font-size: clamp(0.6rem, 2.5vw, 1rem);
    color: var(--color-surface);
    margin-top: 0.3rem;
    letter-spacing: 0.03em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 90%;
    text-align: center;
  }
</style>
