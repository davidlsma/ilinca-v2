---
const navLinks = [
  { href: '/#nosotros',  label: 'Nosotros' },
  { href: '/#menu',      label: 'Menú' },
  { href: '/#eventos',   label: 'Eventos' },
  { href: '/#galeria',   label: 'Galería' },
  { href: '/#reservas',  label: 'Reservaciones' },
];

const horarios = [
  { dia: 'Viernes',  horario: '20:30 – 02:30' },
  { dia: 'Sábado',   horario: '20:30 – 03:00' },
  { dia: 'Domingo',  horario: '13:30 – 18:30' },
];

const year = new Date().getFullYear();
---

<footer style="background-color: var(--color-dark); border-top: 1px solid rgba(245,237,216,0.08);">
  <div class="site-container" style="padding-top: 4rem; padding-bottom: 2.5rem;">

    <div class="footer-grid">

      <!-- Logo + descripción -->
      <div>
        <a href="/" class="footer-logo" aria-label="ILINCA — Inicio">
          <img
            src="/assets/images/logo.jpg"
            alt="ILINCA Resto Bar"
            width="56"
            height="56"
            loading="lazy"
            class="footer-logo-img"
          />
          <span class="footer-logo-name">ILINCA</span>
        </a>
        <p style="color: var(--color-on-dark-muted); font-size: 0.875rem; line-height: 1.7; margin-top: 1.25rem; max-width: 28ch;">
          Resto Bar rural en Rivadavia, San Juan. Cocina casera, música en vivo y buenos momentos.
        </p>
      </div>

      <!-- Navegación -->
      <div>
        <p class="label-sm" style="color: var(--color-primary); margin-bottom: 1.25rem;">Navegación</p>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Horarios -->
      <div>
        <p class="label-sm" style="color: var(--color-primary); margin-bottom: 1.25rem;">Horarios</p>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
          {horarios.map(h => (
            <li style="display: flex; justify-content: space-between; gap: 1rem;">
              <span style="color: var(--color-on-dark-muted); font-size: 0.875rem;">{h.dia}</span>
              <span style="color: var(--color-on-dark); font-size: 0.875rem; font-weight: 600;">{h.horario}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <p class="label-sm" style="color: var(--color-primary); margin-bottom: 1.25rem;">Contacto</p>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <p style="color: var(--color-on-dark-muted); font-size: 0.875rem; line-height: 1.5;">
            Morón Sur 1031<br />
            Rivadavia, San Juan, Argentina
          </p>
          <a
            href="https://wa.me/5492644162855"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
          >
            +54 9 264 416-2855
          </a>
          <a
            href="https://instagram.com/ilinca.restobar"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
            style="display: flex; align-items: center; gap: 0.4rem;"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            @ilinca.restobar
          </a>
        </div>
      </div>

    </div>

    <!-- Copyright -->
    <div style="border-top: 1px solid rgba(245,237,216,0.08); margin-top: 3rem; padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <p style="color: var(--color-on-dark-muted); font-size: 0.75rem;">
        © {year} ILINCA Resto Bar. Todos los derechos reservados.
      </p>
      <p style="color: var(--color-on-dark-muted); font-size: 0.75rem;">
        Rivadavia, San Juan, Argentina
      </p>
    </div>

  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  .footer-logo {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    text-decoration: none;
  }

  .footer-logo-img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid rgba(245,237,216,0.2);
  }

  .footer-logo-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--color-on-dark);
    text-transform: uppercase;
  }

  .footer-link {
    color: var(--color-on-dark-muted);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-on-dark);
  }
</style>
