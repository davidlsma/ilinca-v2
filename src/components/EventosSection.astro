---
---

<section
  id="eventos"
  class="section-pad"
  style="background-color: var(--color-surface);"
>
  <div class="site-container">
    <div class="eventos-grid">

      <!-- Texto -->
      <div class="eventos-text-col">
        <p class="label-sm fade-in" style="color: var(--color-primary); margin-bottom: 1rem;">
          Lo que pasa acá
        </p>
        <h2 class="heading-xl fade-in" style="color: var(--color-on-surface); margin-bottom: 2rem;">
          Noches con música y mucho más
        </h2>
        <p class="body-lg fade-in" style="color: var(--color-on-surface-muted); margin-bottom: 1.25rem;">
          En ILINCA organizamos noches especiales con bandas en vivo, eventos temáticos y encuentros para grupos. Cada fecha es una excusa para reunirse, comer bien y crear recuerdos en un ambiente único.
        </p>
        <p class="body-lg fade-in" style="color: var(--color-on-surface-muted); margin-bottom: 2.5rem;">
          La música forma parte de la experiencia. Artistas locales, propuestas variadas y siempre el calor de un espacio que siente como propio. Seguinos en Instagram para enterarte de lo que se viene.
        </p>

        <div class="flex flex-wrap gap-4 fade-in">
          <a
            href="https://instagram.com/ilinca.restobar"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Ver en Instagram
          </a>
        </div>
      </div>

      <!-- Imágenes -->
      <div class="eventos-img-col fade-in" style="display: flex; flex-direction: column; gap: 0.5rem;">
        <img
          src="/assets/images/evento-1.jpg"
          alt="Banda en vivo en ILINCA Resto Bar"
          loading="lazy"
          width="800"
          height="500"
          class="eventos-img"
        />
        <img
          src="/assets/images/evento-2.jpg"
          alt="Evento en ILINCA Resto Bar"
          loading="lazy"
          width="800"
          height="500"
          class="eventos-img"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .eventos-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .eventos-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }

  .eventos-img {
    width: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    max-height: 240px;
  }

  .eventos-text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
</style>
