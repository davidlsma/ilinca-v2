import GaleriaSection from '../components/GaleriaSection.astro';
import ReservasSection from '../components/ReservasSection.astro';
import FooterSection from '../components/FooterSection.astro';
---

<BaseLayout>
  <Nav />
  <main>
    <HeroSection />
    <NosotrosSection />
    <MenuSection />
    <EventosSection />
